# Ghostty - MacBook Pro Developer Setup
# =============================================================================

# WINDOW
macos-titlebar-style = tabs
window-padding-x = 12
window-padding-y = 8
window-padding-color = extend

# THEME - Auto light/dark
theme = "dark:greyscale-dark,light:greyscale-light"

# FONT - JetBrains Mono Nerd Font
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 18
font-thicken = true
adjust-cell-width = 5%
adjust-cell-height = 25%

# CURSOR
cursor-style = block
cursor-style-blink = false
shell-integration-features = cursor,sudo,title

# SCROLLBACK
scrollback-limit = 50000
image-storage-limit = 320000000

# BEHAVIOR
copy-on-select = clipboard
mouse-hide-while-typing = true
confirm-close-surface = false
quit-after-last-window-closed = true

# MACOS
macos-option-as-alt = true
macos-window-shadow = true
window-save-state = always

# KEYBINDS
keybind = super+ctrl+f=toggle_fullscreen
keybind = super+t=new_tab
keybind = super+n=new_window
keybind = super+w=close_surface
keybind = super+shift+left=previous_tab
keybind = super+shift+right=next_tab
keybind = super+k=clear_screen
keybind = super+plus=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+zero=reset_font_size
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5
keybind = shift+enter=text:\x1b\r
